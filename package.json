{
  "name": "sistema-contable-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Double-entry accounting application monorepo",
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "backend:dev": "npm run start:dev --workspace=backend",
    "frontend:dev": "npm run dev --workspace=frontend",
    "shared:build": "npm run build --workspace=shared",
    "test": "npm run test --workspaces",
    "test:integration": "npm run test:integration --workspace=backend"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  }
}
